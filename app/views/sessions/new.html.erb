<% content_for :title, "Login - Fresh Stack" %>

<div class="auth-container">
  <div class="auth-form">
    <h2>Login to Fresh Stack</h2>
    
    <%= form_with url: login_path, local: true, class: "form" do |form| %>
      <div class="form-group">
        <%= form.label :email, class: "form-label" %>
        <%= form.email_field :email, required: true, class: "form-control", placeholder: "Enter your email" %>
      </div>

      <div class="form-group">
        <%= form.label :password, class: "form-label" %>
        <%= form.password_field :password, required: true, class: "form-control", placeholder: "Enter your password" %>
      </div>

      <div class="form-actions">
        <%= form.submit "Login", class: "btn btn-primary" %>
      </div>
    <% end %>

    <div class="auth-links">
      <p>Don't have an account? <%= link_to "Sign up here", signup_path %></p>
    </div>
  </div>
</div>