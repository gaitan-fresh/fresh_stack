<% content_for :title, "Ask a Question - Fresh Stack" %>

<div class="form-container">
  <h1>Ask a Question</h1>
  
  <%= form_with model: @question, local: true, multipart: true, class: "form" do |form| %>
    <% if @question.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@question.errors.count, "error") %> prohibited this question from being saved:</h4>
        <ul>
          <% @question.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :title, class: "form-label" %>
      <%= form.text_field :title, class: "form-control", placeholder: "What's your question? Be specific." %>
      <small class="form-text">Make your title clear and descriptive</small>
    </div>

    <div class="form-group">
      <%= form.label :body, "Details", class: "form-label" %>
      <%= form.text_area :body, rows: 8, class: "form-control", placeholder: "Provide more details about your question..." %>
      <small class="form-text">Include all the information someone would need to answer your question</small>
    </div>

    <div class="form-group">
      <%= form.label :tag_ids, "Existing Tags", class: "form-label" %>
      <%= form.collection_check_boxes :tag_ids, current_tenant.tags, :id, :name do |b| %>
        <div class="checkbox-item">
          <%= b.check_box(class: "form-check-input") %>
          <%= b.label(class: "form-check-label") %>
        </div>
      <% end %>
      <small class="form-text">Select from existing tags</small>
    </div>

    <div class="form-group">
      <%= form.label :new_tags, "New Tags", class: "form-label" %>
      <%= form.text_field :new_tags, class: "form-control", placeholder: "Enter new tags separated by commas (e.g., javascript, react, frontend)" %>
      <small class="form-text">Add new tags separated by commas. They will be created automatically.</small>
    </div>

    <div class="form-group">
      <%= form.label :images, "Images", class: "form-label" %>
      <%= render 'shared/image_upload_simple', 
                 max_files: 10, 
                 max_size: 5.megabytes, 
                 field_name: 'question[images][]' %>
      <small class="form-text">Add images to illustrate your question (max 10 images, 5MB each)</small>
    </div>

    <div class="form-actions">
      <%= form.submit "Post Question", class: "btn btn-primary" %>
      <%= link_to "Cancel", questions_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>