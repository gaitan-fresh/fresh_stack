<% content_for :title, "#{@blog.title} - Fresh Stack" %>

<article class="blog-detail">
  <header class="blog-header">
    <h1><%= @blog.title %></h1>
    <div class="blog-actions">
      <% if current_user == @blog.user %>
        <%= link_to "Edit", edit_blog_path(@blog), class: "btn btn-sm btn-outline" %>
        <%= link_to "Delete", @blog, data: { "turbo-method": :delete, "turbo-confirm": "Are you sure?" }, class: "btn btn-sm btn-danger" %>
      <% end %>
    </div>
  </header>

  <div class="blog-meta">
    <span class="author">
      by <%= link_to @blog.user.name, @blog.user %>
    </span>
    <span class="date">
      <%= @blog.created_at.strftime("%B %d, %Y at %I:%M %p") %>
    </span>
  </div>

  <div class="blog-content">
    <%= simple_format(@blog.body) %>
  </div>

  <div class="blog-tags">
    <% @blog.tags.each do |tag| %>
      <%= link_to tag.name, blogs_path(tag: tag.name), class: "tag-badge" %>
    <% end %>
  </div>

  <% if @blog.questions.any? %>
    <div class="related-questions">
      <h3>Related Questions</h3>
      <div class="questions-list">
        <% @blog.questions.each do |question| %>
          <div class="question-item">
            <h4><%= link_to question.title, question %></h4>
            <div class="question-stats">
              <span><%= pluralize(question.responses.count, "answer") %></span>
              <span><%= pluralize(question.vote_score, "vote") %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="blog-navigation">
    <%= link_to "← Back to Blogs", blogs_path, class: "btn btn-secondary" %>
  </div>
</article>
